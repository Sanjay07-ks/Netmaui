<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PersonalExpenseTracker.ViewModels"
             x:Class="PersonalExpenseTracker.Views.CategoryDetailPage"
             Title="Category Details"
             BackgroundColor="{StaticResource AppBg}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border BackgroundColor="{StaticResource AppCard}" Stroke="{StaticResource AppCardBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20">
                <VerticalStackLayout Spacing="20">

                    <Border BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 25" WidthRequest="80" HeightRequest="80" HorizontalOptions="Center" Margin="0,0,0,10">
                        <Label Text="{Binding Icon}" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="CATEGORY NAME" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <Entry Text="{Binding Name}" Placeholder="e.g. Utilities" PlaceholderColor="{StaticResource AppCardBorder}" TextColor="{StaticResource AppText}" BackgroundColor="Transparent" FontSize="16" />
                        <BoxView HeightRequest="1" Color="{StaticResource AppCardBorder}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="EMOJI ICON" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <Entry Text="{Binding Icon}" Placeholder="e.g. ⚡" PlaceholderColor="{StaticResource AppCardBorder}" TextColor="{StaticResource AppText}" BackgroundColor="Transparent" FontSize="20" MaxLength="4" />
                        <BoxView HeightRequest="1" Color="{StaticResource AppCardBorder}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Button Text="Save Category" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource AppAccent}" TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="12" HeightRequest="50" Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
