<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PersonalExpenseTracker.ViewModels"
             x:Class="PersonalExpenseTracker.Views.AddEditExpensePage"
             Title="Expense Details"
             BackgroundColor="{StaticResource AppBg}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Border BackgroundColor="{StaticResource AppCard}" Stroke="{StaticResource AppCardBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="20">
                <VerticalStackLayout Spacing="15">
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="TITLE" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <Entry Text="{Binding TitleStr}" Placeholder="What was this for?" PlaceholderColor="{StaticResource AppCardBorder}" TextColor="{StaticResource AppText}" BackgroundColor="Transparent" FontSize="16" />
                        <BoxView HeightRequest="1" Color="{StaticResource AppCardBorder}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="AMOUNT" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <Entry Text="{Binding Amount}" Placeholder="0.00" Keyboard="Numeric" PlaceholderColor="{StaticResource AppCardBorder}" TextColor="{StaticResource AppSuccess}" BackgroundColor="Transparent" FontSize="24" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="{StaticResource AppCardBorder}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="CATEGORY" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <Picker ItemsSource="{Binding Categories}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedCategory}" Title="Select Category" TitleColor="{StaticResource AppCardBorder}" TextColor="{StaticResource AppAccent}" BackgroundColor="Transparent" />
                        <BoxView HeightRequest="1" Color="{StaticResource AppCardBorder}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="DATE" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <DatePicker Date="{Binding Date}" TextColor="{StaticResource AppText}" BackgroundColor="Transparent" />
                        <BoxView HeightRequest="1" Color="{StaticResource AppCardBorder}" Margin="0,5,0,0"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="NOTES" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" TextColor="{StaticResource AppSubText}" />
                        <Editor Text="{Binding Note}" Placeholder="Optional details..." PlaceholderColor="{StaticResource AppCardBorder}" TextColor="{StaticResource AppText}" BackgroundColor="Transparent" HeightRequest="80" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Button Text="Save Expense" Command="{Binding SaveCommand}" BackgroundColor="{StaticResource AppAccent}" TextColor="White" FontAttributes="Bold" FontSize="16" CornerRadius="12" HeightRequest="50" Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
