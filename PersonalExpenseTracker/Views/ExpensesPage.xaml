<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PersonalExpenseTracker.ViewModels"
             xmlns:models="clr-namespace:PersonalExpenseTracker.Models"
             x:Class="PersonalExpenseTracker.Views.ExpensesPage"
             Title="Expenses"
             BackgroundColor="{StaticResource AppBg}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add" Command="{Binding AddExpenseCommand}" />
    </ContentPage.ToolbarItems>

    <Grid>
        <CollectionView ItemsSource="{Binding Expenses}"
                        SelectionMode="None"
                        Margin="20">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15" Margin="0,100,0,0">
                    <Border BackgroundColor="{StaticResource AppCard}" Stroke="{StaticResource AppCardBorder}" StrokeThickness="1" StrokeShape="RoundRectangle 50" WidthRequest="100" HeightRequest="100" HorizontalOptions="Center">
                        <Label Text="💸" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="No Expenses" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource AppText}" HorizontalOptions="Center"/>
                    <Label Text="Start tracking your spending today." FontSize="14" TextColor="{StaticResource AppSubText}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Expense">
                    <SwipeView Margin="0,0,0,12">
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete" BackgroundColor="{StaticResource AppDanger}" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ExpensesViewModel}}, Path=DeleteExpenseCommand}" CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border BackgroundColor="{StaticResource AppCard}"
                                Stroke="{StaticResource AppCardBorder}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="15">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ExpensesViewModel}}, Path=EditExpenseCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15" VerticalOptions="Center">
                                <Border BackgroundColor="{StaticResource AppBg}" StrokeThickness="0" StrokeShape="RoundRectangle 12" WidthRequest="50" HeightRequest="50">
                                    <Label Text="{Binding Category.Icon}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource AppText}" />
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="{Binding Category.Name}" FontSize="12" TextColor="{StaticResource AppAccent}" />
                                        <Label Text="•" FontSize="12" TextColor="{StaticResource AppSubText}" />
                                        <Label Text="{Binding Date, StringFormat='{0:MMM dd}'}" FontSize="12" TextColor="{StaticResource AppSubText}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                
                                <Label Grid.Column="2" Text="{Binding Amount, StringFormat='${0:N2}'}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource AppSuccess}" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
