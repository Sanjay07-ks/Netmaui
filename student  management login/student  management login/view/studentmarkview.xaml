<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="student__management_login.view.studentmarkview"
             Title="studentmarkview">
    <CollectionView ItemsSource="{Binding StudentDetail}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <StackLayout>
                    <Label Text="{Binding studentName}" FontSize="Medium"/>
                    <Label Text="{Binding department}" FontSize="Medium"/>
                    <Label Text="{Binding tamilmark}" FontSize="Medium"/>
                    <Label Text="{Binding englishmark}" FontSize="Medium"/>
                    <Label Text="{Binding mathmark }" FontSize="Medium"/>
                    <Label Text="{Binding sciencemark }" FontSize="Medium"/>
                    <Label Text="{Binding socialmark }" FontSize="Medium"/>
                </StackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>
     </CollectionView>
</ContentPage>